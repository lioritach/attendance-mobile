<mvc:View
    controllerName="attendanceshabas.attendanceshabas.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"

>
    <Page id="idPage" showHeader="false" class="mainPage">
    <!-- MAIN SCREEN -->

       <VBox id="idVBox" class="mainContainer">
                <!-- Header -->
            <HBox id="idHBox" width="100%" height="10%" justifyContent="End" class="headerBar">
                <Image id="menu" class="menu" src="../css/images/group.svg" press="openMyMenu" />
                   <!-- <Image  src="../css/images/ring.svg" type="Transparent"/> -->
             </HBox>
             <HBox id="idBodyBox"  justifyContent="Center" height="100%">
             <VBox
               justifyContent="Start">
                 
            
                 <HBox id="goodmorning" justifyContent="Center" width="100%">
                 <Text class="goodDayN" text="{i18n>goodDayN}" />            
                </HBox>         
                
                <HBox id="circle-main-hbox" class="circle-main-hbox" width="100%" justifyContent="Center">
                    <HBox id="hbox-circle" class="hbox-circle">
                        <VBox id="circle-vbox" justifyContent="Center">
                          <Text class="circle-enterTime" text="{i18n>clockIn}" /> 
                          <Text  id="circle-enter" class="circle-enter" text="{i18n>enter}" />   
                        </VBox>
                        
                    </HBox>
               </HBox>
               <HBox id="hbox-clockTime" justifyContent="Center" visible="false">
                <VBox >
                    <Text class="clockenter-text" text="{i18n>clockenter}"/>
                    <Text class="app-text" text="{i18n>location} {i18n>application}" />
                </VBox>
               </HBox>  
             </VBox>
             </HBox>    
            <HBox id="idFooter">
                <HBox class="footer-hbox">
                      <HBox id="hbox-footer-body" class="hbox-footer-body">
                        <Button id="animButton"  icon="../css/images/Navigation.svg" press=".onAnimatePress" class="moveableButton" ></Button>
                        <Text class="footer-text" text="פירוט נוכחות חודשית" />
                      </HBox>  
                </HBox>
            </HBox>
               
        </VBox>
    </Page>
</mvc:View>
