<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="menu-Dialog"
        class="menu-Dialog"
        stretch="true"
        showHeader="false"
    >
        <VBox class="Menu-content">
            <!-- Header -->
            <HBox class="menu-header" justifyContent="End">
                <Button
                    class="close-menu"
                    icon="../css/images/close.svg"
                    press="closeMyMenu"
                />
            </HBox>

            <!-- Body עם List -->
            <List class="menu-list" inset="false" mode="None">

                <StandardListItem
				class="menu-row"
                    title="{i18n>DailyReport}"
                    icon="../css/images/Calendar.svg"
                    type="Active"
                    press="onMenuItemPress">
                    <customData>
                        <core:CustomData key="route" value="DailyReport"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="menu-row"
                    title="{i18n>MonthlyAttendance}"
                    icon="../css/images/CalendarAtt.svg"
                    type="Active"
                    press="onMenuItemPress">
                    <customData>
                        <core:CustomData key="route" value="monthlyAttendance"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="menu-row"
                    title="{i18n>AbsenceReport}"
                    icon="../css/images/CalendarClose.svg"
                    type="Active"
                    press="onMenuItemPress">
                    <customData>
                        <core:CustomData key="route" value="absenceReport"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="menu-row"
                    title="{i18n>MyBalances}"
                    icon="../css/images/CalendarPlus.svg"
                    type="Active"
                    press="onMenuItemPress">
                    <customData>
                        <core:CustomData key="route" value="balances"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="menu-row"
                    title="{i18n>MyWorkArrangement}"
                    icon="../css/images/CalendarList.svg"
                    type="Active"
                    press="onMenuItemPress">
                    <customData>
                        <core:CustomData key="route" value="workArrangement"/>
                    </customData>
                </StandardListItem>

            </List>

            <!-- Footer -->
            <HBox class="menu-footer">
                <HBox width="20%">
                    <Image
                        class="image-panel"
                        src="../css/images/openPanel.svg"
                        press="openDetailsEmp"
                    />
                </HBox>

                <VBox width="80%" justifyContent="SpaceBetween">
                    <HBox class="menu-details" justifyContent="SpaceAround">
                        <Text
                            class="image-txt"
                            text="{i18n>fullName}"
                        />
                        <Image
                            class="image-menu"
                            src="../css/images/image.svg"
                        />
                    </HBox>
                </VBox>
            </HBox>

        </VBox>
    </Dialog>
</core:FragmentDefinition>