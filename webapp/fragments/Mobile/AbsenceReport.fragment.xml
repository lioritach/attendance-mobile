<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">
    <VBox class="mainContainer">
        <HBox
            width="100%"
            class="MobileHeaderBar" alignItems="Center">
            <Button
                class="MobileButtonMenu"
                icon="sap-icon://navigation-left-arrow"
                press="onBack"/> 
            <Label text="{i18n>AbsenceReport}" class="MobileMediumText sapUiMediumMarginBeginEnd"/>
            <Label text=""/>
        </HBox> 

        <VBox height="100%" class="sapUiMediumMarginTop sapUiContentPadding">
            
            <Panel 
            expandable="true" 
            headerText="{clockModel>/DailyReport/ReasonDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel">
                <content>
                    <List inset="false" 
                    mode="SingleSelectMaster" 
                    items="{clockModel>/DailyReport/ReasonList}"
                    selectionChange="MobReasonSelect">
                        <StandardListItem
                        class="MobileReasonRow"
                            title="{clockModel>TextCode}">
                        </StandardListItem>
                    </List>
                </content>
            </Panel>
            <Panel 
            expandable="true" 
            expand=".MobExpandPanelRemark"
            headerText="{clockModel>/DailyReport/RemarkDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel sapMBtnIconLeft">
                <content>
                    <u:Calendar
                    select=".MobAbsenceCalendarSelect"
                    showWeekNumbers="false"
                    intervalSelection="true"
                    class="MobileCalendar"/>
                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                        <Button text="{i18n>Clear}" 
                        press=".MobDailyApprove"
                        class="MobileApproveButton"
                        enabled="{clockModel>/DailyReport/Approve}"/>                    
                        <Button text="{i18n>Approve}" 
                        press=".MobDailyApprove"
                        class="MobileApproveButton"
                        enabled="{clockModel>/DailyReport/Approve}"/>                        
                    </HBox>                       
                </content>
            </Panel>  
            <Panel 
            expandable="true" 
            expand=".MobExpandPanelRemark"
            headerText="{clockModel>/DailyReport/RemarkDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel">
                <content>
                    <TextArea class="MobileTextArea" 
                    width="100%" 
                    rows="6" 
                    value="{clockModel>/DailyReport/Remark}" 
                    liveChange="MobDailyRemarkChange"
                    valueLiveUpdate="true"/>
                </content>
            </Panel>            
        </VBox>

        <HBox class="MobileFooterBox">
            <HBox class="MobileFooterBodySmall" justifyContent="End" alignItems="Center">
                <Button text="{i18n>Approve}" 
                press=".MobDailyApprove"
                class="MobileApproveButton"
                enabled="{clockModel>/DailyReport/Approve}"/>
            </HBox>   
        </HBox>            
    </VBox>
</core:FragmentDefinition>
