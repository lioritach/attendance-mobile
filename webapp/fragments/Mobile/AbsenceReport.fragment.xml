<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">
    <VBox class="mainContainer">
        <HBox
            width="100%"
            class="MobileHeaderBar" alignItems="Center">
            <Button
                class="MobileButtonMenu"
                icon="sap-icon://navigation-left-arrow"
                press="onBack"/> 
            <Label text="{i18n>AbsenceReport}" class="MobileMediumText sapUiMediumMarginBeginEnd"/>
            <Label text=""/>
        </HBox> 

        <VBox height="100%" class="sapUiTinyMarginTop sapUiContentPadding">
            
            <Panel 
            expandable="true" 
            expand=".MobOnPanelExpand"
            headerText="{clockModel>/AnsenceReport/ReasonDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel">
                <content>
                <ScrollContainer
                    height="15rem"
                    width="100%"
                    horizontal="false"
                    vertical="true"
                    focusable="true">
                        <List inset="false" 
                        mode="SingleSelectMaster" 
                        items="{path: 'clockModel>/ReasonsList', templateShareable: false,
                        filters: [{
                            path: 'CompleteDay',
                            operator: 'EQ',
                            value1: true
                            }] }"
                        selectionChange="MobMonthlyReasonSelect">
                            <StandardListItem
                            class="MobileReasonRow"
                                title="{clockModel>TextCode}">
                            </StandardListItem>
                        </List>
                    </ScrollContainer>
                </content>
            </Panel>
            <Panel visible="{clockModel>/AnsenceReport/Absence/ReportFullDays}"
            expandable="true" 
            expand=".MobOnPanelExpand"
            headerText="{clockModel>/AnsenceReport/PeriodDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel sapMBtnIconLeft">
                <content>
                    <u:Calendar
                    select=".MobAbsenceCalendarSelect"
                    showWeekNumbers="false"
                    intervalSelection="{clockModel>/AnsenceReport/Absence/PeriodReport}"
                    class="MobileCalendar"/>
                    <HBox height="3rem" justifyContent="SpaceBetween" alignItems="Center">
                        <Button text="{i18n>Clear}" 
                        press=".MobDailyApprove"
                        type="Transparent"
                        class="MobileApproveButton"/>                    
                        <Button text="{i18n>Approve}" 
                        press=".MobDailyApprove"
                        class="MobileApproveButton"/>                        
                    </HBox>                       
                </content>
            </Panel> 

            <Panel visible="{clockModel>/AnsenceReport/Absence/ReportHours}"
            expandable="true" 
            expand=".MobOnPanelExpand"
            headerText="{clockModel>/AnsenceReport/HoursDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel sapMBtnIconLeft">
                <content>

                </content>
            </Panel>    
            <Panel visible="{clockModel>/AnsenceReport/Absence/AddFile}"
            expandable="true" 
            expand=".MobOnPanelExpand"
            headerText="{clockModel>/AnsenceReport/AttachmentDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel sapMBtnIconLeft">
                <content>

                </content>
            </Panel>  
            <Panel 
            expandable="true" 
            expand=".MobOnPanelExpand"
            headerText="{clockModel>/AnsenceReport/RemarkDef}" 
            width="auto" 
            class="sapUiResponsiveMargin MobilePanel">
                <content>
                    <TextArea class="MobileTextArea" 
                    width="100%" 
                    rows="6" 
                    value="{clockModel>/AnsenceReport/Remark}" 
                    liveChange="MobDailyRemarkChange"
                    valueLiveUpdate="true"/>
                </content>
            </Panel>            
        </VBox>

        <HBox class="MobileFooterBox">
            <HBox class="MobileFooterBodySmall" justifyContent="End" alignItems="Center">
                <Button text="{i18n>Approve}" 
                press=".MobDailyApprove"
                class="MobileApproveButton"
                enabled="{clockModel>/AnsenceReport/Approve}"/>
            </HBox>   
        </HBox>            
    </VBox>
</core:FragmentDefinition>
