<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
        <VBox class="mainContainer">
            <!-- Header -->
            <HBox
                width="100%"
                class="MobileHeaderBar"
                justifyContent="Start">
                    <Button
                        class="MobileButtonMenu"
                        icon="sap-icon://decline"
                        press="onBack"/>  
                                
            </HBox>            
            <!-- Body тн List -->
            <VBox height="100%">
            <List inset="false" 
                mode="SingleSelectMaster" 
                selectionChange="onMenuItemPress"
                class="sapUiMediumMarginTop">

                <StandardListItem
				class="MobileMenuRow"
                    title="{i18n>DailyReport}"
                    icon="../css/images/Calendar.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="route" value="DailyReport"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileMenuRow"
                    title="{i18n>MonthlyAttendance}"
                    icon="../css/images/CalendarAtt.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="route" value="monthlyAttendance"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileMenuRow"
                    title="{i18n>AbsenceReport}"
                    icon="../css/images/CalendarClose.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="route" value="AbsenceReport"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileMenuRow"
                    title="{i18n>MyBalances}"
                    icon="../css/images/CalendarPlus.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="route" value="balances"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileMenuRow"
                    title="{i18n>MyWorkArrangement}"
                    icon="../css/images/CalendarList.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="route" value="workArrangement"/>
                    </customData>
                </StandardListItem>

            </List>
            </VBox>
            <!-- Footer -->
            <HBox justifyContent="Center" alignItems="Center" class="MobileMenuFooter">
                <VBox width="80%">
                    <HBox alignItems="Center">
                        <Avatar
							src="{clockModel>/Employee/ImgEmp}"
							displaySize="M"
							showBorder="true"
							press=".openDetailsEmp"/>
                        <Text
                            class="MobileMediumText sapUiSmallMarginBeginEnd"
                            text="{clockModel>/Employee/Name}"/>                        
                    </HBox>
                </VBox>
                <HBox width="20%" justifyContent="End">
                    <Image
                        class="MobileDetailsImage"
                        src="../css/images/openPanel.svg"
                        press="openDetailsEmp"/>
                </HBox>

                
            </HBox>

        </VBox>
</core:FragmentDefinition>