<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<Popover
		class="MobilePopover"
		showHeader="false"
		placement="Bottom">
		<List inset="false" 
                mode="SingleSelectMaster" 
                selectionChange="onMenuItemPress"
                class="sapUiMediumMarginTop">

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>MonthlyAttendance}"
                    icon="../css/images/Calendar.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="monthlyAttendance"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>AbsenceReport}"
                    icon="../css/images/CalendarClose.svg"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="AbsenceReport"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>NightShift}"
                    icon="sap-icon://dark-mode"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="AbsenceReport"/>
                    </customData>
                </StandardListItem>
                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>View}"
                    icon="sap-icon://document-text"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="ViewMonthlyEntrie"/>
                    </customData>
                </StandardListItem>
                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>DailyRemark}"
                    icon="sap-icon://text-align-justified"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="ViewMonthlyEntrie"/>
                    </customData>
                </StandardListItem>
            </List>
	</Popover>
</core:FragmentDefinition>