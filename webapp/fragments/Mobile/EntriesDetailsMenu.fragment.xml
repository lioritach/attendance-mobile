<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<Popover
		class="sapUiResponsivePadding--header sapUiResponsivePadding--footer"
		showHeader="false"
		placement="Bottom">
		<List inset="false" 
                mode="SingleSelectMaster" 
                selectionChange="onMenuItemPress"
                class="sapUiMediumMarginTop">

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>Edit}"
                    icon="sap-icon://edit"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="EditMonthlyEntrie"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>Delete}"
                    icon="sap-icon://delete"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="DeleteMonthlyEntrie"/>
                    </customData>
                </StandardListItem>

                <StandardListItem
				class="MobileActionMenuRow"
                    title="{i18n>View}"
                    icon="sap-icon://document-text"
                    iconDensityAware="false">
                    <customData>
                        <core:CustomData key="itemAction" value="ViewMonthlyEntrie"/>
                    </customData>
                </StandardListItem>
            </List>
	</Popover>
</core:FragmentDefinition>