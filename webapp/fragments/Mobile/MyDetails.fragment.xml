<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
>
	<Dialog
		class="MobileDetailsDialog"
		stretch="true"
		showHeader="false">
		<VBox
			class="MobileDetailsDialogBody"
			height="100%"
		>
			<HBox class="MobileMenuFooter" justifyContent="SpaceBetween" alignItems="Center">
				<VBox height="100%">
					<HBox alignItems="Center">
						<Avatar
							src="{clockModel>/Employee/ImgEmp}"
							displaySize="M"
							showBorder="true"
							press=".closeDetailsEmp"/>
						<Text
							class="MobileMediumText sapUiMediumMarginBeginEnd"
							text="{clockModel>/Employee/Name}"/>
					</HBox>
				</VBox>
				<VBox height="100%" class="app-details-closePanel">
					<Image
						class="MobileDetailsImage"
						src="../css/images/closePanel.svg"
						press="closeDetailsEmp"/>
				</VBox>
				
			</HBox>
			<VBox class="app-myDetails-body">
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>EmployeeNumber}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="{clockModel>/Employee/PersonaNumber}"/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>EmployeeType}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="{clockModel>/Employee/EmployeeSubgroupName}"/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>WorkLog}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="{clockModel>/Employee/WorkScheduleName}"/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>CardNumber}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="???"/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>Commander}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="{clockModel>/Employee/MangName}"/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>HumanResourcesOfficer}"/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="{clockModel>/Employee/MashaName}"/>
					</VBox>
					
				</HBox>
			</VBox>
			<HBox />
		</VBox>
	</Dialog>
</core:FragmentDefinition>