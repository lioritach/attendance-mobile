<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
>
	<Dialog
		class="MobileDetailsDialog"
		stretch="true"
		showHeader="false">
		<VBox
			class="MobileDetailsDialogBody"
			height="100%"
		>
			<HBox class="MobileMenuFooter" justifyContent="SpaceBetween" alignItems="Center">
				<VBox height="100%">
					<HBox alignItems="Center">
						<Image
							class="image-menu sapUiMediumMarginEnd"
							src="../css/images/image.svg"/>
						<Text
							class="MobileMediumText"
							text="{i18n>fullName}"/>
					</HBox>
				</VBox>
				<VBox height="100%" class="app-details-closePanel">
					<Image
						class="MobileDetailsImage"
						src="../css/images/closePanel.svg"
						press="closeDetailsEmp"
					/>
				</VBox>
				
			</HBox>
			<VBox class="app-myDetails-body">
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>EmployeeNumber}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="00787135"
						/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>EmployeeType}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="סוהר קבוע"
						/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>WorkLog}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="עובד יום"
						/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>CardNumber}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="0099928881"
						/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>Commander}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="אלי ישראלי"
						/>
					</VBox>
					
				</HBox>
				<HBox class="MobileDetailsItem">
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemDescriptionText"
							text="{i18n>HumanResourcesOfficer}"
						/>
					</VBox>
					<VBox justifyContent="Center">
						<Text
							class="MobileDetailsItemValueText"
							text="אלי ויצמן"
						/>
					</VBox>
					
				</HBox>
			</VBox>
			<HBox />
		</VBox>
	</Dialog>
</core:FragmentDefinition>